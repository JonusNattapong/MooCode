{
  "name": "moocode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI-first local coding agent inspired by Claude Code workflows",
  "license": "MIT",
  "bin": {
    "moocode": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx ./src/index.ts",
    "start": "node dist/index.js",
    "check": "biome check . --write && tsc --noEmit -p tsconfig.json",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "version:patch": "npm version patch -m 'release: v%s'",
    "version:minor": "npm version minor -m 'release: v%s'",
    "version:major": "npm version major -m 'release: v%s'",
    "release": "npm run check && npm run build && npm version patch -m 'release: v%s' && git push && git push --tags"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "blessed": "^0.1.81",
    "chalk": "^5.4.1",
    "conf": "^15.1.0",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "execa": "^9.6.1",
    "globby": "^16.1.1",
    "ignore": "^7.0.4",
    "ora": "^9.3.0",
    "prompts": "^2.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/blessed": "^0.1.25",
    "@types/diff": "^8.0.0",
    "@types/node": "^24.0.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
