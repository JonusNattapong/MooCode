{
  "name": "moocode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI-first local coding agent inspired by Claude Code workflows",
  "license": "MIT",
  "bin": {
    "moocode": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx ./src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "version:patch": "npm version patch -m 'release: v%s'",
    "version:minor": "npm version minor -m 'release: v%s'",
    "version:major": "npm version major -m 'release: v%s'",
    "release": "npm run check && npm run build && npm version patch -m 'release: v%s' && git push && git push --tags"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "diff": "^7.0.0",
    "ignore": "^7.0.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/diff": "^7.0.1",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
